# ============================================================
# SkillHire AI - Backend Environment Variables
# Set these in Render dashboard under "Environment"
# NEVER commit this file with real values!
# ============================================================

# ── Database (Render PostgreSQL) ──────────────────────────
DATABASE_URL=jdbc:postgresql://your-db-host.render.com:5432/skillhire_db
DATABASE_USERNAME=skillhire_user
DATABASE_PASSWORD=your_strong_database_password

# ── JWT ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=your_super_long_random_jwt_secret_at_least_64_characters_long_for_hs256
JWT_EXPIRATION=86400000

# ── Gemini AI ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...your_gemini_api_key_here

# ── Gmail SMTP ─────────────────────────────────────────────
# 1. Enable 2FA on Gmail
# 2. Go to Google Account → Security → App Passwords
# 3. Generate an "App Password" for Mail
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char App Password (no spaces when setting)
MAIL_FROM=noreply@skillhire.ai

# ── CORS ──────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
ALLOWED_ORIGINS=https://skillhire-ai.vercel.app,https://your-custom-domain.com

# ── Frontend URL (used in emails) ─────────────────────────
FRONTEND_URL=https://skillhire-ai.vercel.app

# ── File Upload ───────────────────────────────────────────
FILE_UPLOAD_DIR=./uploads/resumes

# ── Port (Render sets this automatically) ─────────────────
PORT=8080
